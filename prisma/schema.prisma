generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Favorite {
  id          String    @id @default(uuid())
  tmdbId      Int       @unique
  title       String
  releaseYear Int?
  posterPath  String?
  overview    String?   @db.Text
  watchedAt   DateTime?
  rating      Decimal?  @db.Decimal(3, 1)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("favorites")
}
