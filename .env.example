# Application
PORT=3000
NODE_ENV=development

# PostgreSQL (host port 5433 — 5432)
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/movies_db?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# Cache TTL (seconds)
CACHE_TTL_SEARCH_SECONDS=900
CACHE_TTL_MOVIE_SECONDS=3600

# TMDB retry
TMDB_RETRY_MAX_ATTEMPTS=3
TMDB_RETRY_BASE_DELAY_MS=200

# Logging
LOG_LEVEL=info

# TMDB (required from Commit 2)
TMDB_API_KEY=your_tmdb_api_key
TMDB_BASE_URL=https://api.themoviedb.org/3
